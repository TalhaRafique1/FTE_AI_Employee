# AI Employee Environment Configuration
# Silver Tier - Keep this file secure and never commit to version control

# =============================================================================
# GMAIL API CONFIGURATION
# =============================================================================
# credentials.json should be in the project root (not in .env)
# The Gmail watcher will automatically find credentials.json

# =============================================================================
# LINKEDIN CONFIGURATION
# =============================================================================
# LinkedIn credentials (optional - can login manually first time)
# LINKEDIN_EMAIL=your.email@example.com
# LINKEDIN_PASSWORD=your_password

# =============================================================================
# VIP SENDERS (comma-separated email addresses)
# =============================================================================
# Emails from these senders will be marked as high priority
VIP_SENDERS=client@example.com,partner@company.com,vip@important.com

# =============================================================================
# ORCHESTRATOR CONFIGURATION
# =============================================================================
# Qwen Code command (default: qwen)
QWEN_CMD=qwen

# Vault path
VAULT_PATH=D:\FTE_AI_Employee\AI_Employee_Vault

# Check interval in seconds (default: 60)
ORCHESTRATOR_INTERVAL=60

# =============================================================================
# WATCHER CONFIGURATION
# =============================================================================
# Gmail check interval in seconds (default: 120)
GMAIL_CHECK_INTERVAL=120

# LinkedIn check interval in seconds (default: 300)
LINKEDIN_CHECK_INTERVAL=300

# Filesystem check interval in seconds (default: 30)
FILESYSTEM_CHECK_INTERVAL=30

# =============================================================================
# APPROVAL THRESHOLDS
# =============================================================================
# Maximum auto-approve amount for invoices (default: 0 = always require approval)
AUTO_APPROVE_INVOICE_AMOUNT=0

# Maximum auto-approve amount for payments (default: 0 = always require approval)
AUTO_APPROVE_PAYMENT_AMOUNT=0

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log retention days
LOG_RETENTION_DAYS=90

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Never commit this file with real credentials
# 2. Store credentials.json separately and securely
# 3. Use environment variables in production
# 4. Rotate credentials regularly
# 5. Enable 2FA on all accounts
