# =============================================================================
.env
credentials.json
*.pickle
*.pkl
.processed_emails.json
.processed_linkedin.json

# =============================================================================
# SESSION DATA
# =============================================================================
**/linkedin_session/
**/.obsidian/

# =============================================================================
# LOGS
# =============================================================================
AI_Employee_Vault/Logs/*.log
AI_Employee_Vault/Logs/*.json
*.log

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
